# ===========================================
# PRODUCTION ENVIRONMENT VARIABLES
# ===========================================
# Copy this to .env for production deployment
# IMPORTANT: Use strong, unique values for all secrets!
# ===========================================

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
# MongoDB credentials - CHANGE THESE!
MONGO_USERNAME=admin
MONGO_PASSWORD=CHANGE_THIS_TO_STRONG_PASSWORD_MIN_32_CHARS
MONGO_DB=fashionai

# ===========================================
# SECURITY CONFIGURATION
# ===========================================
# JWT Secret - MUST BE CHANGED! Use at least 64 characters
# Generate: openssl rand -base64 64
JWT_SECRET=CHANGE_THIS_TO_RANDOM_STRING_MIN_64_CHARS_USE_openssl_rand_base64_64

# ===========================================
# APPLICATION CONFIGURATION
# ===========================================
# Client/Frontend URLs - Update with your actual domain
# For multiple origins, separate with commas: https://yourdomain.com,https://www.yourdomain.com
CLIENT_ORIGIN=https://yourdomain.com

# Backend API URL (used by frontend)
# If using nginx reverse proxy, this should be your domain/api
VITE_API_URL=https://yourdomain.com/api

# AI Service URL (used by frontend)
# If using nginx reverse proxy, this should be your domain/ai
VITE_AI_SERVICE_URL=https://yourdomain.com/ai

# ===========================================
# OPTIONAL: GPU CONFIGURATION
# ===========================================
# Uncomment to enable GPU support (requires NVIDIA GPU and nvidia-docker)
# NVIDIA_VISIBLE_DEVICES=all

# ===========================================
# DEPLOYMENT PLATFORM SPECIFIC
# ===========================================
# Add platform-specific variables here (e.g., AWS, GCP, Azure)

# Example for AWS:
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key

# Example for custom ports (if not using standard 80/443):
# HTTP_PORT=8080
# HTTPS_PORT=8443

# ===========================================
# SECURITY CHECKLIST
# ===========================================
# Before deploying to production:
# [ ] Changed MONGO_PASSWORD to a strong password (min 32 chars)
# [ ] Generated new JWT_SECRET using: openssl rand -base64 64
# [ ] Updated CLIENT_ORIGIN with your actual domain(s)
# [ ] Updated VITE_API_URL and VITE_AI_SERVICE_URL
# [ ] Reviewed and set all other necessary environment variables
# [ ] Never committed this .env file to version control
# [ ] Set up SSL certificates in config/nginx/ssl/
# [ ] Configured firewall rules (allow only ports 80, 443)
# [ ] Enabled HTTPS redirect in nginx configuration
# ===========================================
