# ==============================================
# FashionAI Studio - AI Service Configuration
# ==============================================

# Environment
ENVIRONMENT=development

# Server Configuration
HOST=0.0.0.0
PORT=8000

# AI Model Settings
MODEL_CACHE_DIR=./models
DEVICE=cuda  # or 'cpu' for CPU-only mode

# Stable Diffusion
STABLE_DIFFUSION_MODEL=stabilityai/stable-diffusion-2-1
SD_GUIDANCE_SCALE=7.5
SD_NUM_INFERENCE_STEPS=50

# CLIP Settings
CLIP_MODEL=openai/clip-vit-base-patch32
CLIP_BATCH_SIZE=32

# FAISS Index
FAISS_INDEX_PATH=./clip_faiss/index.faiss
FAISS_METADATA_PATH=./clip_faiss/meta.npy
FAISS_DIMENSION=512

# Dataset Paths
DATASET_PATH=./data/fashion_dataset
GENERATED_IMAGES_PATH=./generated_images

# Uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760  # 10MB in bytes

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/ai_service.log

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
ALLOW_CREDENTIALS=true

# Performance
WORKERS=4
TIMEOUT=300
