# ==============================================
# FashionAI Studio - Frontend Configuration
# ==============================================

# API Endpoints
VITE_API_URL=http://localhost:5000
VITE_AI_SERVICE_URL=http://localhost:8000

# Environment
VITE_ENV=development

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_TRENDS=true
VITE_ENABLE_AI_DESIGN=true

# Authentication
VITE_JWT_STORAGE_KEY=fashionai_token
VITE_SESSION_TIMEOUT=3600000  # 1 hour in ms

# Upload Settings
VITE_MAX_FILE_SIZE=10485760  # 10MB
VITE_ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp

# UI Configuration
VITE_APP_NAME=FashionAI Studio
VITE_APP_TAGLINE=AI-Powered Fashion Design Platform
VITE_THEME_COLOR=#6366f1

# Analytics (Optional)
# VITE_GA_TRACKING_ID=G-XXXXXXXXXX
# VITE_MIXPANEL_TOKEN=your-mixpanel-token

# Social Media (Optional)
# VITE_FACEBOOK_APP_ID=your-facebook-app-id
# VITE_GOOGLE_CLIENT_ID=your-google-client-id

# Debug Mode
VITE_DEBUG=false
VITE_CONSOLE_LOGS=true
