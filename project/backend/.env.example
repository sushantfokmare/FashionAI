PORT=5000
# MongoDB Atlas connection string. Replace USERNAME, PASSWORD, CLUSTER, and DBNAME.
# Example: mongodb+srv://myuser:MyP@ssw0rd@cluster0.abcde.mongodb.net/fashionai?retryWrites=true&w=majority&appName=Cluster0
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/DBNAME?retryWrites=true&w=majority&appName=Cluster0

# Strong random secret for signing JWTs
JWT_SECRET=replace-with-strong-secret

# Set to true only when serving frontend over HTTPS (e.g., production on Vercel/Netlify with HTTPS)
COOKIE_SECURE=false

# Your frontend origin (Vite default)
CLIENT_ORIGIN=http://localhost:5173
# Python AI Service URL
AI_SERVICE_URL=http://localhost:8000